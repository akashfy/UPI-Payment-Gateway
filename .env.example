# ==========================================
# UPIShield Gateway Environment Configuration
# ==========================================

# Your Gmail Address (used to receive UPI payment emails)
GMAIL_EMAIL="your_gmail_id@gmail.com"

# Your Gmail App Password (16-character code, NOT your regular password)
# Generate it here: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD="your_16_digit_app_password"

# Server Port (include the colon, e.g., :8080)
SERVER_PORT=":8080"

# Your UPI ID (displayed on the landing page)
UPI_ID="your_upi_id@bank"

# Optional: Set the required amount for the product (default is 299 if not set)
REQUIRED_AMOUNT="299"
